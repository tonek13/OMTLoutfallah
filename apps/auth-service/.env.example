NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=omt_user
DB_PASSWORD=replace_with_strong_password
DB_NAME=omt_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (>= 32 chars)
JWT_SECRET=replace_with_very_long_random_access_secret_32_plus
JWT_REFRESH_SECRET=replace_with_very_long_random_refresh_secret_32_plus

# Email OTP provider (required in production)
# Recommended for Render free tier (HTTP API, no SMTP ports required)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=OMT Lebanon <no-reply@yourdomain.com>

# SMTP fallback (optional)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=replace_with_gmail_app_password

# Security
ALLOWED_ORIGINS=http://localhost:3000
ENABLE_SWAGGER=true
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
